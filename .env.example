# Azure/Entra Configuration
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here

# Credential: use ONE of the two options below.
#
# Option 1 (dev only): client secret.
CLIENT_SECRET=your-client-secret-here
#
# Option 2 (recommended for production): certificate auth.
# Set both variables and they take precedence over CLIENT_SECRET.
# CLIENT_CERT_PATH=./cert.pem
# CLIENT_CERT_THUMBPRINT=AA11BB22CC33DD44EE55FF66...

# Frontier Preview Flag (set to true if enrolled)
FRONTIER_PREVIEW_ENABLED=false
